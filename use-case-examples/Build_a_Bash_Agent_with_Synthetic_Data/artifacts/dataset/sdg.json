      {
        "name": "input",
        "drop": false,
        "column_type": "llm-text",
        "prompt": "Generate a natural user request for the LangGraph CLI.\n\nCommand: {{ command }}\n\n{% if command == 'new' %}The user wants to create a new project with the '{{ template }}' template.{% if include_path %} They want it in a custom directory.{% endif %}{% elif command == 'dev' %}The user wants to start the dev server on port {{ port }}.{% if no_browser %} They don't want to auto-open a browser.{% endif %}{% elif command == 'up' %}The user wants to launch the server container on port {{ port }}.{% if watch %} They want to watch for code changes.{% endif %}{% elif command == 'build' %}The user wants to build a Docker image with tag '{{ image_tag }}'.{% elif command == 'dockerfile' %}The user wants to generate a Dockerfile at '{{ dockerfile_path }}'.{% endif %}\n\nWrite one natural, conversational sentence.",
        "model_alias": "command-generator",
        "system_prompt": "Output only a single sentence. No explanation.",
        "multi_modal_context": null
      },
      {
        "name": "output",
        "drop": false,
        "column_type": "llm-structured",
        "prompt": "Convert this user request to a LangGraph CLI tool-call.\n\nCommand type: {{ command }}\nUser request: {{ input }}\n\n{% if command == 'new' %}Set: template, and path if specified.{% elif command == 'dev' %}Set: port, and no_browser if specified.{% elif command == 'up' %}Set: port, and watch if specified.{% elif command == 'build' %}Set: tag.{% elif command == 'dockerfile' %}Set: output_path.{% endif %}\n\nOnly set fields relevant to the command. Leave others as null.",
        "model_alias": "command-generator",
        "system_prompt": "Output ONLY the JSON object. No preamble, no quotes, no meta-commentary.",
        "multi_modal_context": null,
        "output_format": {
          "properties": {
            "command": {
              "description": "CLI command: new, dev, up, build, or dockerfile",
              "title": "Command",
              "type": "string"
            },
            "template": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Template name for 'new' command",
              "title": "Template"
            },
            "path": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Project path for 'new' command",
              "title": "Path"
            },
            "port": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Port for 'dev' or 'up' command",
              "title": "Port"
            },
            "no_browser": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Skip browser for 'dev' command",
              "title": "No Browser"
            },
            "watch": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Watch mode for 'up' command",
              "title": "Watch"
            },
            "tag": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Image tag for 'build' command",
              "title": "Tag"
            },
            "output_path": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Output path for 'dockerfile' command",
              "title": "Output Path"
            }
          },
          "required": [
            "command"
          ],
          "title": "CLIToolCall",
          "type": "object"
        }
      }
    ],
    "model_configs": [
